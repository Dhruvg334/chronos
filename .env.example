# ChronOS Monorepo Environment Configuration

# Backend API Configuration
ENV=development
PORT=8000

# Temporary Dev Auth
# Use a UUID from `docs/chronos/DB_VERIFICATION.md` as a mock user ID for local testing.
DEV_USER_ID=your_test_user_uuid_here

# Google Gemini API
# Backend ONLY. Never expose this to the frontend.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_REASONING=gemini-2.5-pro
GEMINI_MODEL_DEFAULT=gemini-2.5-flash

# Supabase Database Configuration (Backend)
# Obtain these by running `supabase status` in the root directory.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_anon_public_key_here
# Backend ONLY. The frontend must NEVER receive the service role key.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# Google OAuth Integration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/auth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly
FRONTEND_URL=http://localhost:5173
ENCRYPTION_KEY=your_base64_encryption_key_here

# Frontend Application Configuration
# (Vite parses keys prefixed with VITE_)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
VITE_API_URL=http://localhost:8000
