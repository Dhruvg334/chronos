# ChronOS Backend Environment Configuration

# Application Mode
ENV=development
PORT=8000

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Database Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key_here

# Google OAuth Integration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/callback

# Security & Encryption
# 32-byte url-safe base64 key for encrypting Google connection OAuth tokens (e.g. generated via cryptography.fernet.Fernet.generate_key())
ENCRYPTION_KEY=your_base64_encryption_key_here
